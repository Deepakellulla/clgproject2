# Telegram API Credentials
# Get these from https://my.telegram.org
API_ID_1=123456789
API_HASH_1=your_api_hash_here
SESSION_STRING=+
ACCOUNT_NUMBER=
MONGODB_URL=
MIN_ACTIVITY=

# Group ID (use negative value for groups, e.g., -1001234567890)
GROUP_ID=-1001234567890

# DM Interval in seconds (default 300 = 5 minutes)
DM_INTERVAL=300

# Delay between DMs in seconds (prevent flood detection)
RATE_LIMIT_DELAY=300

# Maximum retry attempts for failed DMs
MAX_RETRIES=3

# Optional: Advanced Features
# Enable database logging
DB_ENABLED=false
DB_URL=sqlite:///userbot.db

# Enable webhook for status updates
WEBHOOK_ENABLED=false
WEBHOOK_URL=your_webhook_url_here

# Enable statistics tracking
STATS_ENABLED=true
